body {
  max-width: 1200px;
  margin: 0 auto;
  padding: 2rem 1.5rem;
  line-height: 1.7;
  background: #0a0a0a;
  color: #c8c8c8;
  font-family: 'SF Mono', 'Fira Code', 'JetBrains Mono', 'Consolas', 'Monaco', monospace;
  font-size: 16px;
  overflow-wrap: break-word;
  word-break: break-word;
}

pre {
  max-width: 100%;
  overflow-x: auto;
  overflow-y: hidden;
  background: #111;
  border: 1px solid #1a1a1a;
  border-left: 2px solid #00ff41;
  border-radius: 2px;
  padding: 1rem;
}

pre code {
  display: block;
  white-space: pre;
  font-size: 0.9em;
}

code {
  background: #111;
  padding: 0.2em 0.4em;
  border-radius: 2px;
  font-size: 0.9em;
  color: #00ff41;
}

h1, h2, h3, h4, h5, h6 {
  color: #00ff41;
  margin-top: 2.5em;
  margin-bottom: 0.75em;
  font-weight: 600;
  letter-spacing: -0.01em;
  text-shadow: 0 0 8px rgba(0, 255, 65, 0.15);
}

h1 { font-size: 2.2em; border-bottom: 1px solid #004d00; padding-bottom: 0.5em; }
h2 { font-size: 1.5em; }
h3 { font-size: 1.2em; color: #33cc55; }
h4 { font-size: 1.05em; color: #33cc55; }
h5 { font-size: 1em; color: #28a045; }
h6 { font-size: 0.95em; color: #28a045; }

.title {
  font-size: 1.6em;
  margin-bottom: 0.25em;
}

a {
  color: #ffd700;
  text-decoration: none;
  border-bottom: 1px solid rgba(255, 215, 0, 0.3);
  transition: color 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
}

a:hover {
  color: #0a0a0a;
  background-color: #ffd700;
  border-bottom-color: #ffd700;
}

hr {
  border: none;
  height: 1px;
  background: #1a1a1a;
  margin: 2.5em 0;
}

ul, ol {
  padding-left: 1.25em;
}

li {
  margin-bottom: 0.6em;
  padding-left: 0.25em;
}

ul > li::marker {
  color: #004d00;
}

ol > li::marker {
  color: #004d00;
  font-weight: 600;
}

blockquote {
  border-left: 2px solid #004d00;
  margin: 1.5em 0;
  padding: 0.5em 1em;
  background: #0d0d0d;
  font-style: italic;
  color: #999;
}

strong {
  color: #e0e0e0;
}

em {
  color: #aaa;
}

s {
  color: #444;
  text-decoration-color: #333;
}

img {
  max-width: 100%;
  height: auto;
  border-radius: 2px;
}

table {
  border-collapse: collapse;
  width: 100%;
  margin: 1.5em 0;
}

th, td {
  border: 1px solid #1a1a1a;
  padding: 0.75em;
  text-align: left;
}

th {
  background: #0d0d0d;
  color: #00ff41;
  font-weight: 600;
}

center {
  margin: 1.5em 0;
}

::selection {
  background: #00ff41;
  color: #000;
}

a:focus-visible {
  outline: 1px solid #ffd700;
  outline-offset: 2px;
}

pre::-webkit-scrollbar {
  height: 4px;
}

pre::-webkit-scrollbar-track {
  background: #0a0a0a;
}

pre::-webkit-scrollbar-thumb {
  background: #222;
  border-radius: 2px;
}

pre::-webkit-scrollbar-thumb:hover {
  background: #333;
}

@media (max-width: 600px) {
  body {
    padding: 1.25rem 1rem;
    font-size: 15px;
  }
  h1 { font-size: 1.7em; }
  h2 { font-size: 1.3em; }
  h3 { font-size: 1.1em; }
}
